# Auto detect text files and normalize line endings to LF
* text=auto eol=lf

# Explicitly set line endings for specific file types
*.tsx text eol=lf
*.ts  text eol=lf
*.js  text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.css  text eol=lf
*.html text eol=lf
*.md   text eol=lf
*.yaml text eol=lf
*.yml  text eol=lf
*.toml text eol=lf
*.java text eol=lf
*.xml  text eol=lf
*.sql  text eol=lf
*.sh   text eol=lf
*.env  text eol=lf

# Binaries — no line-ending conversion
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.webp binary
*.svg  binary
*.woff binary
*.woff2 binary
*.ttf  binary
*.eot  binary
